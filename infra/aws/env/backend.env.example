APP_ENV=production
APP_DEBUG=false
APP_URL=https://app.example.com
APP_LOG_LEVEL=info
APP_PORT=8080
APP_KEY=replace-with-a-real-secret

LOG_TYPE=single
LOG_LEVEL=info

DB_CONNECTION=postgresql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=video_db
DB_USERNAME=video
DB_PASSWORD=change-me

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAIN_DB=1

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_ENABLED=false
RABBITMQ_USER=video
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=video_saas
RABBITMQ_EXCHANGE=video.tasks
RABBITMQ_EXCHANGE_TYPE=direct
RABBITMQ_QUEUE=video.tasks.generate
RABBITMQ_ROUTING_KEY=video.generate
RABBITMQ_DLX=video.tasks.dlx
RABBITMQ_DLQ=video.tasks.generate.dlq
RABBITMQ_DLQ_ROUTING_KEY=video.generate.dlq
RABBITMQ_RETRY_QUEUE=video.tasks.generate.retry
RABBITMQ_RETRY_ROUTING_KEY=video.generate.retry
RABBITMQ_RETRY_DELAY_MS=10000

DEEPSEEK_ENABLED=false
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_HTTP_TIMEOUT_SEC=90

WANXIANG_ENABLED=false
WANXIANG_BASE_URL=https://dashscope.aliyuncs.com
WANXIANG_API_KEY=
WANXIANG_MODEL=wan2.6-t2i
WANXIANG_CREATE_PATH=/api/v1/services/aigc/multimodal-generation/generation
WANXIANG_TASK_PATH_TEMPLATE=/api/v1/tasks/%s
WANXIANG_SIZE=1280*1280
WANXIANG_PROMPT_EXTEND=true
WANXIANG_NUM_IMAGES=1
WANXIANG_HTTP_TIMEOUT_SEC=120
WANXIANG_POLL_INTERVAL_SEC=5
WANXIANG_MAX_POLL_ATTEMPTS=60
