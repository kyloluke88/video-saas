PODCAST_MODE=production
BGM_ENABLED=false

DB_CONNECTION=postgresql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=video_db
DB_USERNAME=video
DB_PASSWORD=video123
DB_SSLMODE=disable
DB_MAX_IDLE_CONNECTIONS=10
DB_MAX_OPEN_CONNECTIONS=25
DB_MAX_LIFE_SECONDS=300

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_MAIN_DB=1

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=video
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=video_saas
RABBITMQ_EXCHANGE=video.tasks
RABBITMQ_EXCHANGE_TYPE=direct
RABBITMQ_QUEUE=video.tasks.generate
RABBITMQ_ROUTING_KEY=video.generate
RABBITMQ_DLX=video.tasks.dlx
RABBITMQ_DLQ=video.tasks.generate.dlq
RABBITMQ_DLQ_ROUTING_KEY=video.generate.dlq
RABBITMQ_RETRY_QUEUE=video.tasks.generate.retry
RABBITMQ_RETRY_ROUTING_KEY=video.generate.retry
RABBITMQ_RETRY_DELAY_MS=10000

WORKER_ASSETS_DIR=/app/assets
FFMPEG_WORK_DIR=/app/outputs
FFMPEG_TIMEOUT_SEC=300
PODCAST_BLOCK_GAP_MS=280
PODCAST_TEMPLATE_GAP_MS=280
WORKER_CONCURRENCY=1

SEEDANCE_ENABLED=false
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=https://seedanceapi.org/v1
SEEDANCE_GENERATE_PATH=/generate
SEEDANCE_STATUS_PATH=/status

GOOGLE_TTS_ENABLED=true
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_USER_PROJECT=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_TTS_URL=https://texttospeech.googleapis.com/v1/text:synthesize
GOOGLE_TTS_MODEL=gemini-2.5-pro-tts
GOOGLE_TTS_AUDIO_ENCODING=MP3
GOOGLE_TTS_SAMPLE_RATE_HZ=24000
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_JA_SPEAKING_RATE=0.85
GOOGLE_TTS_JA_MALE_VOICE_ID=
GOOGLE_TTS_JA_FEMALE_VOICE_ID=
GOOGLE_TTS_ZH_MALE_VOICE_ID=
GOOGLE_TTS_ZH_FEMALE_VOICE_ID=
GOOGLE_TTS_PROMPT_APPEND=
GOOGLE_TTS_ZH_PROMPT_APPEND=
GOOGLE_TTS_JA_PROMPT_APPEND=

ELEVENLABS_TTS_ENABLED=true
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_DIALOGUE_PATH=/v1/text-to-dialogue/with-timestamps
ELEVENLABS_TTS_MODEL=eleven_v3
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_TTS_SPEED=0.8
ELEVENLABS_TTS_PROMPT_APPEND=
ELEVENLABS_TTS_ZH_PROMPT_APPEND=
ELEVENLABS_TTS_JA_PROMPT_APPEND=
ELEVENLABS_TTS_PROMPT_MAX_BYTES=1200
ELEVENLABS_TTS_MALE_VOICE_ID=
ELEVENLABS_TTS_FEMALE_VOICE_ID=

MFA_ENABLED=true
MFA_COMMAND=mfa
MFA_TEMPORARY_DIRECTORY=
MFA_ZH_DICTIONARY=mandarin_china_mfa
MFA_ZH_ACOUSTIC_MODEL=mandarin_mfa
MFA_ZH_G2P_MODEL=mandarin_china_mfa
MFA_JA_DICTIONARY=japanese_mfa
MFA_JA_ACOUSTIC_MODEL=japanese_mfa
MFA_JA_G2P_MODEL=japanese_mfa

S3_ENABLED=false
# AWS S3: leave S3_ENDPOINT empty.
# Cloudflare R2 / MinIO: set S3_ENDPOINT to the compatible API endpoint.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Public base URL used to build downloadable links, for example:
# https://your-bucket.s3.us-east-1.amazonaws.com
# https://cdn.example.com
S3_PUBLIC_URL=
