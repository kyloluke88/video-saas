SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=https://seedanceapi.org/v1
SEEDANCE_GENERATE_PATH=/generate
SEEDANCE_STATUS_PATH=/status
SEEDANCE_ENABLED=true

WORKER_ASSETS_DIR=/app/assets
FFMPEG_WORK_DIR=/app/outputs
FFMPEG_TIMEOUT_SEC=300
PODCAST_X264_PRESET=veryfast
PRACTICAL_FFMPEG_TIMEOUT_SEC=0
PRACTICAL_X264_PRESET=veryfast
PRACTICAL_X264_THREADS=4
PRACTICAL_FPS=24
PODCAST_BLOCK_GAP_MS=280
PODCAST_TEMPLATE_GAP_MS=280
# Practical dialogue timing:
# PRACTICAL_TURN_GAP_MS inserts fixed silence between turns inside one chapter.
# PRACTICAL_CHAPTER_GAP_MS keeps the current chapter image frozen after the chapter ends, before the next chapter image.
# PRACTICAL_BLOCK_GAP_MS keeps the last chapter image of the current section frozen after the block ends, before switching to the next section cover.
# PRACTICAL_CHAPTER_TRANSITION_LEAD_MS keeps the chapter image on screen before chapter dialogue starts. This mainly affects chapter 2+ inside the same block.
# PRACTICAL_BLOCK_TRANSITION_LEAD_MS keeps the block cover on screen after the block topic audio ends, before switching to the first chapter image.
# PRACTICAL_SUBTITLE_LEAD_MS shifts subtitle display earlier than audio when needed.
PRACTICAL_TURN_GAP_MS=500
PRACTICAL_CHAPTER_GAP_MS=1800
PRACTICAL_BLOCK_GAP_MS=2200
PRACTICAL_CHAPTER_TRANSITION_LEAD_MS=1000
PRACTICAL_BLOCK_TRANSITION_LEAD_MS=1000
PRACTICAL_SUBTITLE_LEAD_MS=0
PRACTICAL_IMAGE=1
PRACTICAL_IMAGE_PROVIDER=flux
PRACTICAL_IMAGE_OUTPUT_FORMAT=png
PRACTICAL_IMAGE_REFS_PER_SPEAKER=2
PRACTICAL_IMAGE_BASE_SEED=0
PRACTICAL_FLUX_BASE_URL=https://api.bfl.ai/v1
PRACTICAL_FLUX_MODEL_PATH=/flux-2-pro
PRACTICAL_FLUX_MODEL_LABEL=flux-2-pro
PRACTICAL_FLUX_API_KEY=
PRACTICAL_FLUX_POLL_INTERVAL_SEC=5
PRACTICAL_FLUX_MAX_POLL_ATTEMPTS=120
PRACTICAL_FLUX_HTTP_TIMEOUT_SEC=60
PRACTICAL_FLUX_PROMPT_UPSAMPLING=false
PRACTICAL_FLUX_SAFETY_TOLERANCE=2

GOOGLE_TTS_ENABLED=true
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_USER_PROJECT=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/app/credentials/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_TTS_URL=https://texttospeech.googleapis.com/v1/text:synthesize
GOOGLE_TTS_MODEL=gemini-2.5-pro-tts
GOOGLE_TTS_AUDIO_ENCODING=MP3
GOOGLE_TTS_SAMPLE_RATE_HZ=24000
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_JA_SPEAKING_RATE=0.85
GOOGLE_TTS_PRACTICAL_JA_SPEAKING_RATE=0.82
GOOGLE_TTS_JA_MALE_VOICE_ID=Alnilam
GOOGLE_TTS_JA_FEMALE_VOICE_ID=Leda
GOOGLE_TTS_PRACTICAL_MALE_VOICE_ID=Alnilam
GOOGLE_TTS_PRACTICAL_FEMALE_VOICE_ID=Leda
# PRACTICAL_TTS_TEMPO applies post-TTS time-stretch before practical alignment and timeline rebuild.
# Lower values make the rendered practical audio slower.
PRACTICAL_TTS_TEMPO=0.78
GOOGLE_TTS_ZH_MALE_VOICE_ID=
GOOGLE_TTS_ZH_FEMALE_VOICE_ID=
GOOGLE_TTS_PROMPT_APPEND=
GOOGLE_TTS_ZH_PROMPT_APPEND=
GOOGLE_TTS_JA_PROMPT_APPEND=
GOOGLE_TTS_PROMPT_MAX_BYTES=1200

